# =============================================================================
#  Markadan — Instance Yapılandırma Şablonu
#  Kullanım: Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
#            cp .env.example .env
# =============================================================================

# ── VERİTABANI ────────────────────────────────────────────────────────────────
# SQL Server SA şifresi: en az 8 karakter, büyük+küçük harf, rakam ve özel karakter
DB_SA_PASSWORD=YourStr0ngSaPassword!

# Bağlantı dizgisi — "db" servis adı Docker ağındaki SQL Server hostname'idir.
# DB_SA_PASSWORD ile aynı şifre olmalı.
ConnectionStrings__DefaultConnection=Server=db;Database=MarkadanDB;User Id=sa;Password=YourStr0ngSaPassword!;TrustServerCertificate=True;

# ── JWT ───────────────────────────────────────────────────────────────────────
# Jwt__Key: en az 32 karakter (256-bit) rastgele üretilmiş gizli anahtar.
# Örnek üretim: openssl rand -base64 32
Jwt__Key=buraya-en-az-32-karakter-uzunlugunda-rastgele-anahtar-yazin
Jwt__Issuer=Markadan
Jwt__Audience=Markadan.Public
Jwt__AccessTokenMinutes=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend'in çalıştığı origin(ler). Birden fazla için __1, __2 ekleyin.
Cors__AllowedOrigins__0=https://magazaniz.com
# Cors__AllowedOrigins__1=https://www.magazaniz.com

# ── ADMIN SEED ────────────────────────────────────────────────────────────────
# İlk açılışta otomatik oluşturulan admin hesabı.
# Sonraki açılışlarda mevcut hesap korunur, yenisi oluşturulmaz.
Seed__AdminEmail=admin@magazaniz.com
Seed__AdminPassword=GucluAdminParolasi1!

# ── ORTAM ────────────────────────────────────────────────────────────────────
# Development → Swagger açık; Production → Swagger kapalı.
ASPNETCORE_ENVIRONMENT=Production

# ── DATA PROTECTION ──────────────────────────────────────────────────────────
# GovId şifrelemesi için key depolama yolu. docker-compose ile otomatik mount edilir.
# Değiştirme — dpkeys volume'u bu dizine bağlı.
# DataProtection__KeysPath=/app/dp-keys

# ── PORT ──────────────────────────────────────────────────────────────────────
# Host makinede API'nin dinleyeceği port (varsayılan: 8080)
API_PORT=8080

# ── RATE LIMIT ────────────────────────────────────────────────────────────────
# Public katalog uçları (GET /products, /brands, /categories) için IP başına limit
# PermitLimit: pencere başına maksimum istek sayısı (varsayılan: 60)
# WindowSeconds: pencere süresi saniye cinsinden (varsayılan: 60)
RateLimit__PermitLimit=60
RateLimit__WindowSeconds=60

# ── E-POSTA (SMTP) ────────────────────────────────────────────────────────────
# Favori bildirimleri ve terk edilen sepet hatırlatmaları için.
# Brevo (eski Sendinblue) ücretsiz 300 mail/gün — butik için yeterli.
# Brevo SMTP: smtp-relay.brevo.com:587, kullanıcı adı = Brevo hesap emaili, şifre = SMTP API anahtarı
Email__SmtpHost=smtp-relay.brevo.com
Email__SmtpPort=587
Email__SmtpUser=brevo-hesap-emailiniz@example.com
Email__SmtpPassword=brevo-smtp-api-anahtariniz
Email__FromAddress=noreply@magazaniz.com
Email__FromName=Mağaza Adı

# ── TERK EDİLEN SEPET ────────────────────────────────────────────────────────
# ThresholdHours: sepet kaç saat hareketsiz kalırsa mail gönderilsin (varsayılan: 2)
# CheckIntervalMinutes: job kaç dakikada bir kontrol etsin (varsayılan: 30)
AbandonedCart__ThresholdHours=2
AbandonedCart__CheckIntervalMinutes=30

# ── STOK UYARISI ──────────────────────────────────────────────────────────────
# Checkout sonrası stok bu eşiğin altına düşen ürünler için admin'e mail gider.
Inventory__LowStockThreshold=5
Inventory__AdminEmail=admin@magazaniz.com
